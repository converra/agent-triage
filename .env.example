# LLM provider API key (one of these is required)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# LangSmith (optional — only needed for --langsmith trace source)
LANGSMITH_API_KEY=

# Axiom (optional — only needed for --axiom trace source)
AXIOM_API_KEY=

# Langfuse (optional — only needed for --langfuse trace source)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com  # uncomment for self-hosted
